    <!-- Bottom Info Panels -->
    <LinearLayout
        android:id="@+id/bottom_info_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/meebles_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- City type -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginEnd="20dp">
            <TextView
                android:id="@+id/bottom_city_text"
                android:text="Village"
                android:textColor="#EDF4C1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"/>
            <ImageView
                android:id="@+id/bottom_city_image"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/city_1"/>
        </LinearLayout>

        <!-- Environment type -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center">

            <TextView
                android:id="@+id/bottom_env_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Volcano"
                android:textColor="#EDF4C1"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/bottom_env_image"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/environment_1"/>
        </LinearLayout>

    </LinearLayout>

    <EditText
        android:id="@+id/nfc_number_et"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:hint="Enter a Number"
        android:textSize="28sp"
        android:textColor="#EDF4C1"
        android:textStyle="bold"
        android:inputType="number"
        android:layout_marginBottom="10dp"
        android:textAlignment="center"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_info_panel"
        app:layout_constraintBottom_toTopOf="@id/withdraw_deposit_toggle"
        android:layout_marginTop="25dp"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/withdraw_deposit_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/nfc_number_et"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="50dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/withdraw">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/withdraw"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textSize="28sp"
            android:textColor="#EDF4C1"
            android:textStyle="bold"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Grab" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deposit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="150dp"
            android:textSize="28sp"
            android:textColor="#EDF4C1"
            android:textStyle="bold"
            android:layout_height="wrap_content"
            android:text="Drop" />

    </com.google.android.material.button.MaterialButtonToggleGroup>



</androidx.constraintlayout.widget.ConstraintLayout>