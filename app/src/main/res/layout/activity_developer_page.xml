<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/logo_background"
    tools:context=".DeveloperPage">

    <LinearLayout
        android:id="@+id/dev_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="16dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/meeble_et"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:hint="Meeble Count"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/city_type_et"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:hint="City Type"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/environment_type_et"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:hint="Environment Type"
            android:inputType="number"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/read_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Read NFC Tag"
            android:backgroundTint="#EDF4C1"
            android:textColor="#EB5A3D"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/write_button"
            android:backgroundTint="#EDF4C1"
            android:textColor="#EB5A3D"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Write NFC Tag"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>